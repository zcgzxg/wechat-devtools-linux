#!/bin/bash

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
root_dir="$( cd -P "$( dirname "$SOURCE" )"/.. >/dev/null 2>&1 && pwd )"
caller_dir="$PWD"

project_appid() {
  local project_path="$1"
  node -e '
const fs = require("fs");
const path = require("path");
const projectPath = process.argv[1];
if (!projectPath) process.exit(0);
const configPath = path.join(projectPath, "project.config.json");
try {
  const appid = JSON.parse(fs.readFileSync(configPath, "utf8")).appid;
  if (typeof appid === "string" && appid.length > 0) process.stdout.write(appid);
} catch (_) {}
' "$project_path"
}

absolute_project_path() {
  local project_path="$1"
  if [[ "$project_path" != /* ]]; then
    project_path="$caller_dir/$project_path"
  fi

  if command -v realpath >/dev/null 2>&1; then
    realpath -m "$project_path"
    return
  fi

  node -e '
const path = require("path");
process.stdout.write(path.resolve(process.argv[1]));
' "$project_path"
}

normalize_cli_args() {
  local normalized=()
  local arg
  local project_path=""
  local has_appid=0
  while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
      --project)
        normalized+=("$arg")
        shift
        if [ "$#" -gt 0 ]; then
          project_path="$(absolute_project_path "$1")"
          normalized+=("$project_path")
        fi
        ;;
      --project=*)
        project_path="$(absolute_project_path "${arg#--project=}")"
        normalized+=("--project=$project_path")
        ;;
      --appid)
        has_appid=1
        normalized+=("$arg")
        shift
        if [ "$#" -gt 0 ]; then
          normalized+=("$1")
        fi
        ;;
      --appid=*)
        has_appid=1
        normalized+=("$arg")
        ;;
      *)
        normalized+=("$arg")
        ;;
    esac
    shift
  done
  if [ "$has_appid" -eq 0 ] && [ -n "$project_path" ]; then
    local appid
    appid="$(project_appid "$project_path")"
    if [ -n "$appid" ]; then
      normalized+=("--appid" "$appid")
    fi
  fi
  printf '%s\0' "${normalized[@]}"
}

readarray -d '' CLI_ARGS < <(normalize_cli_args "$@")

for ((idx=0; idx<${#CLI_ARGS[@]}; idx++)); do
  case "${CLI_ARGS[$idx]}" in
    --appid)
      if [ $((idx + 1)) -lt ${#CLI_ARGS[@]} ]; then
        export WECHAT_DEVTOOLS_APPID="${CLI_ARGS[$((idx + 1))]}"
      fi
      ;;
    --appid=*)
      export WECHAT_DEVTOOLS_APPID="${CLI_ARGS[$idx]#--appid=}"
      ;;
  esac
done

cd "$root_dir/bin"

if [ -z "$XDG_CONFIG_HOME" ];then
  DATA_DIR=$HOME/.config
else
  DATA_DIR=$XDG_CONFIG_HOME
fi

APP_DIR="$root_dir/package.electron/app"
APP_NAME="wechatwebdevtools"
PACKAGE_NAME="wechat-devtools"
if [ -f "$APP_DIR/package.json" ]; then
  PARSED_APP_NAME=$(grep -m 1 -o '"appname"[[:space:]]*:[[:space:]]*"[^"]*"' "$APP_DIR/package.json" | sed 's/.*"appname"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
  if [ -z "$PARSED_APP_NAME" ]; then
    PARSED_APP_NAME="$PACKAGE_NAME"
  fi
  if [ -n "$PARSED_APP_NAME" ]; then
    APP_NAME="$PARSED_APP_NAME"
  fi
fi
CLI="$APP_DIR/js/common/cli/index.js"
IDE_HTTP_PORT=9420

export WECHAT_DEVTOOLS_DIR="$root_dir/electron"
export APPDATA="$DATA_DIR/$APP_NAME"
export USERPROFILE="$APPDATA"
export PATH="$root_dir/electron:$PATH"
export ELECTRON_RUN_AS_NODE=1
export WECHAT_DEVTOOLS_CLI_CWD="$caller_dir"
mkdir -p "$APPDATA/Default"

if command -v md5sum >/dev/null 2>&1; then
  PRODUCT_HASH=$(printf '%s' "$root_dir/electron/resources/app.asar" | md5sum | cut -d ' ' -f 1)
  APP_USER_DATA_DIR="$USERPROFILE/AppData/Local/$APP_NAME/User Data/$PRODUCT_HASH/Default"
  PACKAGE_USER_DATA_DIR="$USERPROFILE/AppData/Local/$PACKAGE_NAME/User Data/$PRODUCT_HASH/Default"
  mkdir -p "$APP_USER_DATA_DIR"
  mkdir -p "$PACKAGE_USER_DATA_DIR"
  printf 'On' > "$PACKAGE_USER_DATA_DIR/.ide-status"
  printf '%s' "$IDE_HTTP_PORT" > "$PACKAGE_USER_DATA_DIR/.ide"
fi

port_ready() {
  timeout 1 bash -c "</dev/tcp/127.0.0.1/$IDE_HTTP_PORT" >/dev/null 2>&1
}

start_gui_if_needed() {
  case "${1:-}" in
    ""|--help|-h|help)
      return 0
      ;;
  esac

  if port_ready; then
    return 0
  fi

  GUI_LAUNCHER="$root_dir/bin/wechat-devtools-nightly"
  if [ ! -x "$GUI_LAUNCHER" ]; then
    GUI_LAUNCHER="$root_dir/bin/wechat-devtools"
  fi

  setsid -f env -u ELECTRON_RUN_AS_NODE "$GUI_LAUNCHER" >/tmp/wechat-devtools-nightly-cli-start.log 2>&1 < /dev/null

  for _ in $(seq 1 60); do
    if port_ready; then
      return 0
    fi
    sleep 1
  done
}

start_gui_if_needed "${CLI_ARGS[0]}"

BOOTSTRAP_JS='const e=process.argv[1]; const a=process.argv.slice(2); process.env.cwd=process.env.WECHAT_DEVTOOLS_CLI_CWD || process.cwd(); process.argv=[process.execPath,"--ms-enable-electron-run-as-node",e,"--electron"].concat(a); require(e);'
"$root_dir/electron/electron" -e "$BOOTSTRAP_JS" "$CLI" "${CLI_ARGS[@]}"
if [ ! -z "$APPIMAGE" ];then
  tail -f /etc/issue
fi
